@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-3 mb-n1" />
            Acceso Restringido
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-4">Verificación de Seguridad:</MudText>
        <MudTextField @bind-Value="inputCode" Label="Código" Variant="Variant.Outlined"
                      InputType="InputType.Password" AutoFocus="true"
                      OnKeyDown="@HandleKeyDown" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Verificar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    private string inputCode = "";

    private void Submit()
    {
        // Devolvemos el código escrito al componente que llamó al diálogo
        MudDialog.Close(DialogResult.Ok(inputCode));
    }

    private void Cancel() => MudDialog.Cancel();

    // Permite dar "Enter" para enviar
    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Submit();
    }
}